document.addEventListener('DOMContentLoaded', () => {
    const savedKey = localStorage.getItem('groqApiKey');
    if (savedKey) {
        document.getElementById('api-key').value = savedKey;
    }

    renderQuickActions();
    // renderActionOptions() serĂĄ chamado apĂłs gerar aĂ§Ă”es dinĂąmicas no loadCase()
});

document.getElementById('api-key').addEventListener('input', function(event) {
    localStorage.setItem('groqApiKey', event.target.value.trim());
});

document.getElementById('case-file').addEventListener('change', function(event) {
    const file = event.target.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const caseData = JSON.parse(e.target.result);
                loadCase(caseData);
            } catch (error) {
                alert('Erro ao carregar o arquivo JSON. Verifique o formato.');
                console.error('Erro ao parsear JSON do caso:', error);
            }
        };
        reader.readAsText(file);
    }
});

let currentCase = null;
let clockInterval = null;
let simTime = 0;
let chatHistory = [];
let currentVitals = {};
let appliedDevices = [];
let performedExams = [];
let dynamicConductActions = [];
let dynamicAccessActions = [];
let closedQuestions = {};

function loadCase(data) {
    currentCase = data;
    document.getElementById('app-container').classList.remove('hidden');

    // Preencher informaĂ§Ă”es localmente (visĂ­veis apenas quando clicado)
    document.getElementById('patient-name').innerText = data.patient.name;
    document.getElementById('patient-age').innerText = data.patient.age;
    document.getElementById('patient-gender').innerText = data.patient.gender;
    document.getElementById('patient-weight').innerText = data.patient.weight;

    // Suporte para novo formato (main_complaint direto) e formato antigo (history.main_complaint)
    const mainComplaint = data.main_complaint || data.history?.main_complaint || '';
    document.getElementById('cc').innerText = mainComplaint;

    // Para o HMA, usar o case description se disponĂ­vel, senĂŁo tentar o formato antigo
    const hmaText = data.case || data.history?.hma || 'InformaĂ§Ă”es do caso nĂŁo disponĂ­veis.';
    document.getElementById('hma').innerText = hmaText;

    // Comorbidades e alergias do formato antigo, se existirem
    const comorbidities = data.history?.comorbidities || [];
    const allergies = data.history?.allergies || [];
    document.getElementById('comorbidities').innerText = comorbidities.join(', ') || 'Nenhuma informada';
    document.getElementById('allergies').innerText = allergies.join(', ') || 'Nenhuma informada';

    // Sinais vitais - tentar novo formato ou antigo
    const initialVitals = data.initial_vitals || extractVitalsFromCase(data.case) || {};
    updateMonitor(initialVitals);

    document.getElementById('physical-exam-results').innerHTML = '';
    document.getElementById('exam-results-list').innerHTML = '';
    document.getElementById('action-log').innerHTML = '';

    // Reset status tracking
    appliedDevices = [];
    performedExams = [];
    updateStatusPanel();

    // Clear custom inputs
    document.getElementById('custom-exam').value = '';
    document.getElementById('custom-access').value = '';
    document.getElementById('custom-conduct').value = '';

    addAction('Caso iniciado.');
    initAI(data);

    // Gerar aĂ§Ă”es e perguntas dinĂąmicas
    generateDynamicActions(data);
    generateClosedQuestions(data);

    simTime = 0;
    if (clockInterval) clearInterval(clockInterval);
    clockInterval = setInterval(() => {
        simTime++;
        updateDynamicMonitor();
    }, 1000);

    showPanel('anamnesis');
}

function updateMonitor(vitals) {
    currentVitals = { ...currentVitals, ...vitals };

    // Target the new monitor panel elements
    const hrEl = document.getElementById('monitor-vital-hr');
    const spo2El = document.getElementById('monitor-vital-spo2');
    const rrEl = document.getElementById('monitor-vital-rr');
    const tempEl = document.getElementById('monitor-vital-temp');
    const bpEl = document.getElementById('monitor-vital-bp');

    if (hrEl && vitals.hr) hrEl.innerText = vitals.hr;
    if (spo2El && vitals.spo2) spo2El.innerText = vitals.spo2;
    if (rrEl && vitals.rr) rrEl.innerText = vitals.rr;
    if (tempEl && vitals.temp) tempEl.innerText = vitals.temp;

    // Only update BP if it's not being measured
    if (bpEl && bpEl.innerText !== 'Aferindo...' && vitals.bp) {
        bpEl.innerText = vitals.bp;
    }
}

function updateDynamicMonitor() {
    if (currentVitals.hr && currentVitals.hr !== '--') {
        const hrBase = parseInt(currentVitals.hr);
        const varHr = Math.floor(Math.random() * 5) - 2; // Oscila de -2 a +2 bpm
        document.getElementById('monitor-vital-hr').innerText = hrBase + varHr;
    }
    
    if (currentVitals.spo2 && currentVitals.spo2 !== '--') {
        const spo2Base = parseInt(currentVitals.spo2);
        let varSpo2 = Math.floor(Math.random() * 3) - 1; // Oscila de -1 a +1 %
        let newSpo2 = spo2Base + varSpo2;
        document.getElementById('monitor-vital-spo2').innerText = newSpo2 > 100 ? 100 : newSpo2;
    }
}

function updateStatusPanel() {
    const devicesList = document.getElementById('devices-list');
    const examsList = document.getElementById('exams-list');
    
    if (devicesList) {
        devicesList.innerHTML = '';
        if (appliedDevices.length === 0) {
            devicesList.innerHTML = '<li style="color: var(--muted);">Nenhum dispositivo aplicado</li>';
        } else {
            appliedDevices.forEach(device => {
                const li = document.createElement('li');
                li.textContent = device;
                devicesList.appendChild(li);
            });
        }
    }
    
    if (examsList) {
        examsList.innerHTML = '';
        if (performedExams.length === 0) {
            examsList.innerHTML = '<li style="color: var(--muted);">Nenhum exame realizado</li>';
        } else {
            performedExams.forEach(exam => {
                const li = document.createElement('li');
                li.textContent = exam;
                examsList.appendChild(li);
            });
        }
    }
}

function trackDevice(deviceName) {
    if (!appliedDevices.includes(deviceName)) {
        appliedDevices.push(deviceName);
        updateStatusPanel();
    }
}

function trackExam(examName) {
    if (!performedExams.includes(examName)) {
        performedExams.push(examName);
        updateStatusPanel();
    }
}

function measureBP() {
    const bpElement = document.getElementById('monitor-vital-bp');
    if (bpElement.innerText === 'Aferindo...') return; 
    
    bpElement.innerText = 'Aferindo...';
    addAction('Aferindo pressĂŁo arterial nĂŁo invasiva...');
    
    setTimeout(() => {
        bpElement.innerText = currentVitals.bp || '--';
        addAction(`PressĂŁo arterial aferida: ${currentVitals.bp}`);
    }, 4000); // 4 segundos simulando o tempo do manguito inflando
}


function showPanel(panelName) {
    document.querySelectorAll('.content-area .panel').forEach(panel => {
        panel.classList.remove('active');
    });

    const target = document.getElementById('panel-' + panelName);
    if (target) {
        target.classList.add('active');
    }

    document.querySelectorAll('.sidebar .tab-btn').forEach(button => {
        const tab = button.dataset.panel;
        button.classList.toggle('active', tab === panelName);
    });
}

function addAction(description) {
    const log = document.getElementById('action-log');
    const li = document.createElement('li');

    const minutes = String(Math.floor(simTime / 60)).padStart(2, '0');
    const seconds = String(simTime % 60).padStart(2, '0');

    li.innerHTML = `<strong>[${minutes}:${seconds}]</strong> ${description}`;
    log.appendChild(li);
    log.parentElement.scrollTop = log.parentElement.scrollHeight;
}

function initAI(caseData) {
    console.log("[DEBUG] Inicializando IA com os dados do caso:", caseData);
    chatHistory = [
        {
            role: "system",
            content: `VocĂȘ Ă© uma IA com duas personalidades para uma simulaĂ§ĂŁo mĂ©dica.

PERSONALIDADE 1: MOTOR DE SIMULAĂĂO (PadrĂŁo)
- Quando o usuĂĄrio envia uma "Conduta realizada:", vocĂȘ age como o motor da simulaĂ§ĂŁo.
- VocĂȘ avalia a conduta e retorna o impacto no paciente.
- Se a conduta solicitada for um exame (ex: ECG, Raio-X, exames de sangue), inclua os achados descritivos no campo "exam_report".
- Sua resposta DEVE ser um JSON com a estrutura: {"feedback_message": "...", "vitals": {...}, "exam_report": "Laudo detalhado (opcional)"}

PERSONALIDADE 2: O PACIENTE
- Quando o usuĂĄrio envia uma pergunta iniciada por "Como paciente, responda:", vocĂȘ assume o papel do paciente.
- VocĂȘ deve responder Ă  pergunta do mĂ©dico baseando-se estritamente nos dados do caso fornecidos abaixo. NĂŁo invente informaĂ§Ă”es. Se a informaĂ§ĂŁo nĂŁo estiver disponĂ­vel, responda que nĂŁo sabe ou nĂŁo se lembra.
- Sua resposta DEVE ser um JSON com a estrutura: {"patient_answer": "Sua resposta como paciente aqui."}

Dados do caso para ambas as personalidades:
${JSON.stringify(caseData, null, 2)}

Responda SEMPRE e ESTRITAMENTE no formato JSON solicitado para a personalidade apropriada.`
        }
    ];
}

async function generateDynamicActions(caseData) {
    const prompt = `Gere lista de exames e condutas para este caso clĂ­nico. 
    
    Retorne um JSON com a estrutura:
    {
        "access_actions": ["aĂ§ĂŁo 1", "aĂ§ĂŁo 2", ...],
        "conduct_actions": ["conduta 1", "conduta 2", ...]
    }
    
    REGRAS:
    - Inclua 5-8 exames RECOMENDADOS (direcionados ao diagnĂłstico)
    - Inclua 5-8 exames CONFUNDIDORES (que podem levar o aluno a investigaĂ§Ă”es desnecessĂĄrias)
    - Inclua 5-8 acessos/dispositivos variados e 3-5 condutas gerais que cabem em qualquer emergĂȘncia
    - Total: mĂ­nimo 25-35 opĂ§Ă”es combinadas
    - Mantenha "Reavaliar paciente" como primeira opĂ§ĂŁo de conduta
    - Formate como lista de strings simples
    `;
    
    try {
        const response = await callGroqAPIGeneration(`GERAR AĂĂES: ${prompt}`, caseData);
        if (response && response.access_actions && response.conduct_actions) {
            dynamicAccessActions = Array.from(new Set(response.access_actions || [])).filter(Boolean);
            dynamicConductActions = Array.from(new Set(response.conduct_actions || [])).filter(Boolean);

            // Normalizar duplicatas sem considerar caixa alta
            dynamicAccessActions = dynamicAccessActions.filter((item, index, arr) => arr.findIndex(v => v.toLowerCase() === item.toLowerCase()) === index);
            dynamicConductActions = dynamicConductActions.filter((item, index, arr) => arr.findIndex(v => v.toLowerCase() === item.toLowerCase()) === index);

            // Garantir que "Reavaliar paciente" estĂĄ no inĂ­cio e visĂ­vel apenas uma vez
            dynamicConductActions = dynamicConductActions.filter(item => item.toLowerCase() !== 'reavaliar paciente');
            dynamicConductActions.unshift('Reavaliar paciente');

            console.log("[DEBUG] AĂ§Ă”es dinĂąmicas geradas:", dynamicAccessActions, dynamicConductActions);
        }
    } catch (error) {
        console.error("[ERRO] Falha ao gerar aĂ§Ă”es dinĂąmicas:", error);
        // Usar valores padrĂŁo se falhar
        dynamicAccessActions = ACCESS_ACTIONS;
        dynamicConductActions = CONDUCT_ACTIONS;
    }
    
    renderActionOptions();
}

async function generateClosedQuestions(caseData) {
    const prompt = `Gere perguntas de anamnese para avaliaĂ§ĂŁo clĂ­nica deste caso.

    Retorne um JSON com a estrutura:
    {
        "categories": {
            "Categoria 1": {
                "questions": [
                    {
                        "question": "Texto da pergunta",
                        "follow_ups": ["Pergunta de seguimento 1", "Pergunta de seguimento 2"]
                    }
                ]
            }
        }
    }

    REGRAS:
    - Crie 4-6 categorias principais, sem perguntas Ăłbvias de sim/nĂŁo.
    - Cada categoria deve conter 3-5 perguntas abertas ou semi-abertas.
    - Inclua follow-up quando fizer sentido, como ramificaĂ§Ă”es baseadas em respostas.
    - NĂŁo gere opĂ§Ă”es de resposta para o aluno; gere apenas perguntas que o mĂ©dico deve fazer ao paciente.
    - Use linguagem clĂ­nica natural e evite pistas Ăłbvias sobre as respostas.
    - Formate como JSON vĂĄlido.
    `;

    try {
        const response = await callGroqAPIGeneration(`GERAR PERGUNTAS: ${prompt}`, caseData);
        if (response && response.categories) {
            closedQuestions = response.categories;
            console.log("[DEBUG] Perguntas fechadas geradas:", closedQuestions);
            renderClosedQuestions();
        }
    } catch (error) {
        console.error("[ERRO] Falha ao gerar perguntas fechadas:", error);
    }
}

function renderClosedQuestions() {
    const container = document.getElementById('closed-questions-container');
    if (!container || !closedQuestions || Object.keys(closedQuestions).length === 0) return;

    container.innerHTML = '';

    for (const [categoryName, categoryData] of Object.entries(closedQuestions)) {
        const categoryDiv = document.createElement('div');
        categoryDiv.className = 'closed-question-category';

        const headerDiv = document.createElement('div');
        headerDiv.className = 'closed-question-category-header';
        headerDiv.onclick = () => {
            categoryDiv.classList.toggle('expanded');
        };
        headerDiv.innerHTML = `
            <span>${categoryName}</span>
            <span class="category-toggle">âŒ</span>
        `;

        const contentDiv = document.createElement('div');
        contentDiv.className = 'closed-question-category-content';

        if (categoryData.questions && Array.isArray(categoryData.questions)) {
            categoryData.questions.forEach(q => {
                const qDiv = document.createElement('div');
                qDiv.className = 'question-item';

                const qText = document.createElement('div');
                qText.className = 'question-text';
                qText.textContent = q.question || q;
                qDiv.appendChild(qText);

                const askBtn = document.createElement('button');
                askBtn.className = 'question-option-btn';
                askBtn.textContent = 'Perguntar ao paciente';
                askBtn.type = 'button';
                askBtn.onclick = () => askClosedQuestion(q.question || q);
                qDiv.appendChild(askBtn);

                if (q.follow_ups && Array.isArray(q.follow_ups) && q.follow_ups.length > 0) {
                    const followUpTitle = document.createElement('div');
                    followUpTitle.style.margin = '12px 0 6px';
                    followUpTitle.style.fontSize = '13px';
                    followUpTitle.style.color = 'var(--text-light)';
                    followUpTitle.textContent = 'Perguntas de seguimento sugeridas:';
                    qDiv.appendChild(followUpTitle);

                    const followUpDiv = document.createElement('div');
                    followUpDiv.className = 'question-options';
                    q.follow_ups.forEach(followUp => {
                        const followBtn = document.createElement('button');
                        followBtn.className = 'question-option-btn';
                        followBtn.textContent = followUp;
                        followBtn.type = 'button';
                        followBtn.onclick = () => askClosedQuestion(followUp);
                        followUpDiv.appendChild(followBtn);
                    });
                    qDiv.appendChild(followUpDiv);
                }

                contentDiv.appendChild(qDiv);
            });
        }

        categoryDiv.appendChild(headerDiv);
        categoryDiv.appendChild(contentDiv);
        container.appendChild(categoryDiv);
    }
}

async function askClosedQuestion(questionText) {
    if (!questionText) return;

    addAnamnesisLog(questionText, 'user');
    addAction(`Pergunta de anamnese: ${questionText}`);

    const thinkingElement = addAnamnesisLog('Paciente respondendo...', 'patient');
    thinkingElement.classList.add('thinking');

    const prompt = `Como paciente, responda Ă  seguinte pergunta do mĂ©dico com informaĂ§Ă”es apenas do caso: "${questionText}"`;
    const aiResponse = await callGroqAPI(prompt);

    thinkingElement.remove();
    if (aiResponse && aiResponse.patient_answer) {
        addAnamnesisLog(aiResponse.patient_answer, 'patient');
    } else {
        addAnamnesisLog('O paciente nĂŁo tem uma resposta clara no momento.', 'patient');
        console.error('Resposta da IA para pergunta fechada invĂĄlida:', aiResponse);
    }
}

function switchAnamnesisTab(tabName, button) {
    // Esconder todas as abas
    document.querySelectorAll('.anamnesis-tab').forEach(tab => {
        tab.classList.remove('active');
    });
    document.querySelectorAll('.tab-header-btn').forEach(btn => {
        btn.classList.remove('active');
    });

    // Mostrar aba selecionada
    const tabElement = document.getElementById(tabName + '-tab');
    if (tabElement) {
        tabElement.classList.add('active');
    }

    if (button) {
        button.classList.add('active');
    }
}

function togglePatientInfo() {
    const section = document.getElementById('patient-info-section');
    if (section) {
        section.style.display = section.style.display === 'none' ? 'block' : 'none';
    }
}

async function callGroqAPIGeneration(prompt, caseData) {
    // Chamada independente para gerar conteĂșdo (nĂŁo usa chatHistory compartilhada)
    const apiKey = document.getElementById('api-key').value.trim();

    if (!apiKey) {
        console.error("[ERRO] Chave da API vazia.");
        return null;
    }

    const generateHistory = [
        {
            role: "system",
            content: `VocĂȘ Ă© um assistente que gera conteĂșdo para simulaĂ§ĂŁo mĂ©dica.
            
Caso clĂ­nico:
${JSON.stringify(caseData, null, 2)}

Responda ESTRITAMENTE em JSON vĂĄlido com a estrutura solicitada.`
        },
        {
            role: "user",
            content: prompt
        }
    ];

    const requestBody = {
        model: 'llama-3.3-70b-versatile',
        messages: generateHistory,
        response_format: { type: 'json_object' },
        temperature: 0.7
    };

    try {
        const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${apiKey}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestBody)
        });

        if (!response.ok) {
            const errorBody = await response.text();
            console.error('[ERRO] Corpo da resposta de erro da API:', errorBody);
            return null;
        }

        const data = await response.json();
        const rawContent = data.choices?.[0]?.message?.content;
        if (!rawContent) {
            console.error('Resposta da IA sem conteĂșdo vĂĄlido.');
            return null;
        }

        return typeof rawContent === 'object' ? rawContent : JSON.parse(rawContent);
    } catch (error) {
        console.error('[ERRO] Falha ao gerar conteĂșdo:', error);
        return null;
    }
}

async function callGroqAPI(prompt) {
    const apiKey = document.getElementById('api-key').value.trim();
    console.log(`[DEBUG] Iniciando chamada API Groq.`);
    console.log(`[DEBUG] Prompt do usuĂĄrio: "${prompt}"`);
    console.log(`[DEBUG] Tamanho da API Key fornecida: ${apiKey.length} caracteres.`);

    if (!apiKey) {
        alert("Por favor, insira a chave da API do Groq no topo da pĂĄgina.");
        console.error("[ERRO] Chave da API vazia.");
        return null;
    }

    if (!apiKey.startsWith('gsk_') || apiKey.length < 40 || apiKey.length > 100) {
        alert("A chave da API parece invĂĄlida. Chaves da Groq comeĂ§am com 'gsk_' e possuem cerca de 56 caracteres. Verifique se copiou a chave correta.");
        console.error(`[ERRO] Formato de API Key suspeito (Tamanho: ${apiKey.length}, ComeĂ§a com gsk_: ${apiKey.startsWith('gsk_')})`);
        return null;
    }

    chatHistory.push({ role: 'user', content: prompt });

    const requestBody = {
        model: 'llama-3.3-70b-versatile',
        messages: chatHistory,
        response_format: { type: 'json_object' },
        temperature: 0.2
    };

    console.log('[DEBUG] Payload da requisiĂ§ĂŁo (JSON):', JSON.stringify(requestBody, null, 2));

    try {
        const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${apiKey}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestBody)
        });

        console.log(`[DEBUG] Status da resposta HTTP: ${response.status} ${response.statusText}`);

        if (!response.ok) {
            const errorBody = await response.text();
            console.error('[ERRO] Corpo da resposta de erro da API:', errorBody);
            throw new Error(`Erro na API: ${response.status} - ${errorBody}`);
        }

        const data = await response.json();
        console.log('[DEBUG] Resposta de sucesso da API (Parsed):', data);

        const rawContent = data.choices?.[0]?.message?.content;
        if (!rawContent) {
            throw new Error('Resposta da IA sem conteĂșdo vĂĄlido.');
        }

        const aiMessage = typeof rawContent === 'string' ? rawContent : JSON.stringify(rawContent);
        chatHistory.push({ role: 'assistant', content: aiMessage });
        return typeof rawContent === 'object' ? rawContent : JSON.parse(rawContent);
    } catch (error) {
        console.error('[ERRO CRĂTICO] Falha ao comunicar com a Groq:', error);
        alert('Erro de comunicaĂ§ĂŁo com a IA. Verifique sua chave de API e o console para detalhes.');
        if (chatHistory.length && chatHistory[chatHistory.length - 1].role === 'user') {
            chatHistory.pop();
        }
        return null;
    }
}

async function performAction(actionDescription) {
    // Verificar se Ă© reavaliar
    if (actionDescription.toLowerCase().includes('reavaliar')) {
        return performReassessment();
    }
    
    addAction(`Solicitado: ${actionDescription}`);
    
    // Limpar input customizado se houver
    const customInputs = ['custom-access', 'custom-conduct'];
    customInputs.forEach(id => {
        const elem = document.getElementById(id);
        if (elem && elem.value.trim() === actionDescription) {
            elem.value = '';
        }
    });
    
    console.log(`[DEBUG] performAction foi chamada com a aĂ§ĂŁo: "${actionDescription}"`);
    const loadingLi = document.createElement('li');
    loadingLi.innerHTML = `<em>IA analisando conduta...</em>`;
    loadingLi.id = 'loading-ai';
    document.getElementById('action-log').prepend(loadingLi);
    
    // Track as device if keyword match
    const deviceKeywords = ['Acesso', 'acesso', 'Sonda', 'sonda', 'Dreno', 'dreno', 'OxigĂȘnio', 'MĂĄscara', 'Capnografia', 'OxĂ­metro', 'VNI', 'IntubaĂ§ĂŁo', 'VentilaĂ§ĂŁo', 'Curativo', 'ImobilizaĂ§ĂŁo', 'Cateter'];
    const isDevice = deviceKeywords.some(kw => actionDescription.includes(kw));
    if (isDevice) trackDevice(actionDescription);
    
    // Track as exam if keyword match
    const examKeywords = ['ECG', 'Hemograma', 'Gasometria', 'Troponina', 'Lactato', 'Raio-X', 'Ultrassom', 'Cateterismo', 'exame'];
    const isExam = examKeywords.some(kw => actionDescription.includes(kw));
    if (isExam) trackExam(actionDescription);
    
    const aiResponse = await callGroqAPI(`Conduta realizada: ${actionDescription}`);
    
    const loader = document.getElementById('loading-ai');
    if (loader) loader.remove();

    if (aiResponse) {
        if (aiResponse.feedback_message) addAction(`EvoluĂ§ĂŁo: ${aiResponse.feedback_message}`);
        if (aiResponse.vitals) updateMonitor(aiResponse.vitals);
        
        // Mostrar resultado: prioritĂĄrio Ă© exam_report, senĂŁo usa feedback_message
        const report = aiResponse.exam_report || aiResponse.feedback_message;
        if (report || isExam) {
            showExamResult(actionDescription, report || 'Resultado em processamento...');
        }
    }
}

async function askPatient() {
    const questionInput = document.getElementById('anamnesis-question');
    const question = questionInput.value.trim();
    if (!question) return;

    addAnamnesisLog(question, 'user');
    questionInput.value = '';
    questionInput.disabled = true;

    const thinkingElement = addAnamnesisLog('Paciente pensando...', 'patient');
    thinkingElement.classList.add('thinking');

    const prompt = `Como paciente, responda Ă  seguinte pergunta do mĂ©dico: "${question}"`;
    const aiResponse = await callGroqAPI(prompt);

    thinkingElement.remove();
    questionInput.disabled = false;
    questionInput.focus();

    if (aiResponse && aiResponse.patient_answer) {
        addAnamnesisLog(aiResponse.patient_answer, 'patient');
    } else {
        addAnamnesisLog('O paciente parece confuso e nĂŁo consegue responder no momento.', 'patient');
        console.error("AI response for patient question was invalid:", aiResponse);
    }
}

function addAnamnesisLog(message, sender) {
    const log = document.getElementById('anamnesis-log');
    const entry = document.createElement('div');
    entry.textContent = message;
    entry.className = `chat-entry ${sender}`;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
    return entry;
}

function administerMed() {
    const route = document.getElementById('med-route').value;
    const name = document.getElementById('med-name').value;
    if(name.trim() !== '') {
        const actionDesc = `Medicamento administrado: ${name} (${route})`;
        document.getElementById('med-name').value = '';
        performAction(actionDesc);
    } else {
        alert('Digite o nome do medicamento e a dose.');
    }
}

