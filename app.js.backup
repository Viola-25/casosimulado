function renderQuickActions() {
    let container = document.getElementById('dynamic-quick-actions');
    
    if (!container) {
        const mainColumn = document.getElementById('main-column');
        container = document.createElement('div');
        container.id = 'dynamic-quick-actions';
        if (mainColumn) {
            mainColumn.appendChild(container);
        }
    }

    container.innerHTML = '<h3>AĂ§Ă”es RĂĄpidas</h3><p>Clique para solicitar exames, aplicar dispositivos ou realizar condutas.</p>';
    
    for (const [category, actions] of Object.entries(QUICK_ACTIONS)) {
        const section = document.createElement('div');
        section.className = 'action-category';
        
        const title = document.createElement('h5');
        title.innerText = category;
        section.appendChild(title);
        
        const btnContainer = document.createElement('div');
        btnContainer.className = 'action-buttons';

        actions.forEach(actionName => {
            const btn = document.createElement('button');
            btn.textContent = actionName;
            btn.type = 'button';
            btn.onclick = () => performAction(actionName);
            
            btnContainer.appendChild(btn);
        });
        
        section.appendChild(btnContainer);
        container.appendChild(section);
    }
}

function renderActionOptions() {
    // Usar aĂ§Ă”es dinĂąmicas se disponĂ­veis, caso contrĂĄrio usar estĂĄticas
    const accessActions = dynamicAccessActions.length > 0 ? dynamicAccessActions : ACCESS_ACTIONS;
    const conductActions = dynamicConductActions.length > 0 ? dynamicConductActions : CONDUCT_ACTIONS;
    
    renderButtonGrid('access-action-options', accessActions, performAction);
    renderButtonGrid('conduct-action-options', conductActions, performAction);
    renderButtonGrid('physical-exam-actions', PHYSICAL_EXAM_ACTIONS, performPhysicalExam);
}

function renderButtonGrid(containerId, actions, actionHandler) {
    const container = document.getElementById(containerId);
    if (!container) return;

    container.innerHTML = '';
    actions.forEach(actionName => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = actionName;
        btn.onclick = () => actionHandler(actionName);
        container.appendChild(btn);
    });
}

async function performPhysicalExam(actionName) {
    addAction(`Exame fĂ­sico: ${actionName}`);
    
    // Limpar input customizado se houver
    const customExamInput = document.getElementById('custom-exam');
    if (customExamInput && customExamInput.value.trim() === actionName) {
        customExamInput.value = '';
    }
    
    // Track as physical exam
    trackExam(actionName);
    
    const resultsContainer = document.getElementById('physical-exam-results');
    if (resultsContainer) {
        const entry = document.createElement('div');
        entry.className = 'exam-card';
        entry.innerHTML = `<h5>${actionName}</h5><p>Coletando achados...</p>`;
        resultsContainer.prepend(entry);
    }

    const aiResponse = await callGroqAPI(`Exame fĂ­sico realizado: ${actionName}`);
    if (aiResponse) {
        const report = aiResponse.exam_report || aiResponse.feedback_message || 'Nenhum achado especĂ­fico retornado.';
        if (resultsContainer) {
            const firstCard = resultsContainer.firstChild;
            if (firstCard) {
                firstCard.innerHTML = `<h5>${actionName}</h5><p>${report}</p>`;
            }
        }

        if (aiResponse.vitals) {
            updateMonitor(aiResponse.vitals);
        }
    } else if (resultsContainer) {
        const firstCard = resultsContainer.firstChild;
        if (firstCard) {
            firstCard.innerHTML = `<h5>${actionName}</h5><p>NĂŁo foi possĂ­vel obter resultado do exame no momento.</p>`;
        }
    }
}

function showExamResult(actionName, report) {
    const list = document.getElementById('exam-results-list');
    if (!list) return;

    const card = document.createElement('div');
    card.className = 'exam-card';
    card.innerHTML = `<h5>${actionName}</h5><p>${report}</p>`;
    list.prepend(card);
}

async function performReassessment() {
    const timeToPass = 5 * 60; // 5 minutos em segundos
    
    addAction(`Reavaliar paciente (apĂłs ${timeToPass / 60} minutos)...`);
    
    const loadingLi = document.createElement('li');
    loadingLi.innerHTML = `<em>Passando tempo e re-avaliando o paciente...</em>`;
    loadingLi.id = 'loading-reassess';
    document.getElementById('action-log').prepend(loadingLi);
    
    // Simular passagem de tempo
    simTime += timeToPass;
    
    // Solicitar re-avaliaĂ§ĂŁo Ă  IA
    const reassessPrompt = `O paciente foi reavaliado apĂłs ${timeToPass / 60} minutos. Como o paciente evolui? Quais sĂŁo os novos sinais vitais?`;
    const aiResponse = await callGroqAPI(`Conduta realizada: ${reassessPrompt}`);
    
    const loader = document.getElementById('loading-reassess');
    if (loader) loader.remove();
    
    if (aiResponse) {
        const report = aiResponse.exam_report || aiResponse.feedback_message || 'Paciente reavaliado. Sem achados relevantes importantes.';
        
        addAction(`ReavaliaĂ§ĂŁo Completa`);
        showExamResult('ReavaliaĂ§ĂŁo ClĂ­nica Completa', report);
        
        // Atualizar vitais se disponibilizado
        if (aiResponse.vitals) {
            updateMonitor(aiResponse.vitals);
            const vitalChanges = Object.entries(aiResponse.vitals)
                .map(([key, val]) => `${key}: ${val}`)
                .join(', ');
            addAction(`Novos sinais vitais: ${vitalChanges}`);
        }
    }
}

// FunĂ§Ă”es auxiliares caso queira usar inputs livres de texto no HTML no futuro
function requestCustomExam() {
    const input = document.getElementById('exam-name');
    if (input && input.value.trim() !== '') { performAction(`Exame solicitado: ${input.value}`); input.value = ''; } 
    else { alert('Digite o nome do exame a ser solicitado.'); }
}

function applyCustomDevice() {
    const input = document.getElementById('device-name');
    if (input && input.value.trim() !== '') { performAction(`Dispositivo aplicado: ${input.value}`); input.value = ''; } 
    else { alert('Digite o nome do dispositivo a ser aplicado.'); }
}

function performCustomProcedure() {
    const input = document.getElementById('procedure-name');
    if (input && input.value.trim() !== '') { performAction(`Procedimento realizado: ${input.value}`); input.value = ''; } 
    else { alert('Digite o nome do procedimento a ser realizado.'); }
// --- FUNÇŐES DE CRIAÇĂO DE CASO --- //

function showCaseCreator() {
    document.getElementById('case-creator').classList.remove('hidden');
    document.getElementById('simulator-interface').classList.add('hidden');
}

function createCaseFromForm() {
    const form = document.getElementById('creator-form');
    const formData = new FormData(form);

    // Validar campos obrigatórios
    const requiredFields = ['difficulty', 'patient-name', 'patient-age', 'patient-gender', 'case-description', 'main-complaint'];
    const missingFields = requiredFields.filter(field => !formData.get(field)?.trim());

    if (missingFields.length > 0) {
        alert(Por favor, preencha os seguintes campos obrigatórios: );
        return;
    }

    // Construir objeto do caso
    const caseData = {
        difficulty: formData.get('difficulty'),
        patient: {
            name: formData.get('patient-name'),
            age: formData.get('patient-age'),
            gender: formData.get('patient-gender'),
            weight: formData.get('patient-weight') || 'Năo informado'
        },
        case: formData.get('case-description'),
        main_complaint: formData.get('main-complaint'),
        observations: formData.get('observations') || '',
        ai_instructions: formData.get('ai-instructions') || ''
    };

    // Carregar o caso criado
    loadCase(caseData);

    // Esconder criador e mostrar simulador
    document.getElementById('case-creator').classList.add('hidden');
    document.getElementById('simulator-interface').classList.remove('hidden');

    // Limpar formulário
    form.reset();
}

function extractVitalsFromCase(caseText) {
    if (!caseText) return {};

    const vitals = {};
    const patterns = {
        hr: /FC\s*(\d+)/i,
        bp: /PA\s*([\d\/]+)/i,
        spo2: /SpO2\s*(\d+)/i,
        rr: /FR\s*(\d+)/i,
        temp: /Temp\s*([\d\.]+)/i
    };

    for (const [key, pattern] of Object.entries(patterns)) {
        const match = caseText.match(pattern);
        if (match) {
            vitals[key] = match[1];
        }
    }

    return vitals;
}
